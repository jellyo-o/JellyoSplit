# ─── Required ─────────────────────────────────────────────
# Database password for PostgreSQL
DB_PASSWORD=changeme
# Secret key for session encryption (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Application ──────────────────────────────────────────
# Public URL where the app is accessible (include port if non-standard)
BASE_URL=http://localhost:3000
# Host port mapped to the container (should match the port in BASE_URL)
EXTERNAL_PORT=3000

# ─── Authentication ───────────────────────────────────────
# Options: 'local' (username/password), 'oidc' (SSO only), 'both'
AUTH_MODE=local

# ─── OIDC / SSO (required if AUTH_MODE is 'oidc' or 'both') ─
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_CALLBACK_URL=http://localhost:3000/api/auth/oidc/callback
